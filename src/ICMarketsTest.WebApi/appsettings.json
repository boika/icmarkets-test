{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore.Hosting.Diagnostics": "Error",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Async",
        "Args": {
          "configure": [
            {
              "Name": "Console"
            }
          ]
        }
      }
    ],
    "Enrich": [
      "FromLogContext",
      "WithMachineName"
    ]
  },

  "PrometheusAspNetCoreOptions": {
    "ScrapeEndpointPath": "/metrics",
    "ScrapeResponseCacheDurationMilliseconds": 500
  },

  "NetworksOptions": {
    "Networks": [
      {
        "Id": "eth-main",
        "Name": "eth",
        "Type": "main"
      },
      {
        "Id": "dash-main",
        "Name": "dash",
        "Type": "main"
      },
      {
        "Id": "btc-main",
        "Name": "btc",
        "Type": "main"
      },
      {
        "Id": "btc-test3",
        "Name": "btc",
        "Type": "test3"
      },
      {
        "Id": "ltc-main",
        "Name": "ltc",
        "Type": "main"
      }
    ]
  },

  "BlockCypherOptions": {
    "BaseUrl": "https://api.blockcypher.com",
    "TotalTimeout": "00:00:10",
    "AttemptTimeout": "00:00:01",
    "MaxRetryAttempts": 3,
    "BaseRetryDelay": "00:00:01"
  },

  "ConnectionStrings": {
    "Storage": "data source=..\\..\\storage\\icmarkets_test.db"
  },

  "AllowedHosts": "*"
}